input {
    keyboard {
        xkb {
            layout "us,sk"
            variant ",qwerty"
            options "grp:alt_space_toggle"
        }

        repeat-rate 35
        repeat-delay 200
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {

    }

    tablet {
        map-to-output "HDMI-A-2"
    }

    focus-follows-mouse max-scroll-amount="90%"
}
